# Backend API Configuration
# For development: http://localhost:8000
# For production: https://your-production-backend-url.com
VITE_API_URL=http://localhost:8000

# Optional bootstrap org API key for non-interactive/demo startup.
# Recommended to set from deployment platform environment variables.
# VITE_API_KEY=your_org_api_key_here

# Example for production:
# VITE_API_URL=https://your-backend-domain.com
