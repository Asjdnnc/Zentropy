# QuantumGuard Production Environment
# ==================================
# Copy to .env in your deployment environment and set real values.

# ─── Runtime ──────────────────────────────────────────────────
ENV=production
API_HOST=0.0.0.0
API_PORT=8000
PROVER_PORT=8001
LOG_LEVEL=INFO

# ─── Starknet ────────────────────────────────────────────────
STARKNET_RPC=https://free-rpc.nethermind.io/sepolia-juno/v0_7
STARKNET_CHAIN_ID=SN_SEPOLIA
STARKNET_PRIVATE_KEY=REPLACE_WITH_REAL_PRIVATE_KEY
STARKNET_ACCOUNT_ADDRESS=REPLACE_WITH_REAL_ACCOUNT_ADDRESS
STARKNET_ACCOUNT_CONFIG=/home/your-user/.starkli/account-sepolia.json
AUTO_DEPLOY_WALLET_ON_REGISTER=true
WALLET_DEPLOY_COMMAND=REPLACE_WITH_DEPLOY_COMMAND_TEMPLATE_USING_{account_address}_AND_{public_key_hash}
WALLET_DEPLOY_TIMEOUT_SECONDS=90

# ─── Security ────────────────────────────────────────────────
RATE_LIMIT_RPM=60
CORS_ORIGINS=https://your-frontend.vercel.app
QUANTUMGUARD_MASTER_SECRET=REPLACE_WITH_64_CHAR_HEX
BOOTSTRAP_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

# ─── Data Paths ──────────────────────────────────────────────
DB_PATH=/data/quantumguard.db
MERKLE_STORAGE_DIR=/data/merkle_batches

# ─── PostgreSQL (docker-compose.prod.yml) ───────────────────
POSTGRES_DB=quantumguard
POSTGRES_USER=quantumguard
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD
DATABASE_URL=postgresql://quantumguard:REPLACE_WITH_STRONG_DB_PASSWORD@postgres:5432/quantumguard
