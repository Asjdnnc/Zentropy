# QuantumGuard Environment Configuration
# ========================================
# Copy this file to .env and adjust values for your environment.
# Loaded automatically by python-dotenv on startup.

# ─── API Server ──────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ─── Starknet ────────────────────────────────────────────────
STARKNET_RPC=https://free-rpc.nethermind.io/sepolia-juno/v0_7
STARKNET_CHAIN_ID=SN_SEPOLIA
STARKNET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
# On-chain address (informational/contract logic)
STARKNET_ACCOUNT_ADDRESS=0xYOUR_ACCOUNT_ADDRESS
# Path to starkli account config JSON used by --account
STARKNET_ACCOUNT_CONFIG=/home/your-user/.starkli/account-sepolia.json

# Auto deploy each newly created wallet account using this shell command template.
# Placeholders: {account_id} {wallet_id} {account_address} {public_key_hash}
AUTO_DEPLOY_WALLET_ON_REGISTER=false
WALLET_DEPLOY_COMMAND=
WALLET_DEPLOY_TIMEOUT_SECONDS=90

# ─── Prover ──────────────────────────────────────────────────
# Leave empty to auto-detect from project structure
# PROVER_BINARY=/path/to/prover
PROVER_PORT=8001

# ─── Database ────────────────────────────────────────────────
# v1 (SQLite only)
DB_PATH=/data/quantumguard.db

# v2 (PostgreSQL primary, SQLite fallback if unset)
# DATABASE_URL=postgresql://quantumguard:secret@localhost:5432/quantumguard
DATABASE_URL=sqlite:///data/quantumguard_v2.db
POSTGRES_DB=quantumguard
POSTGRES_USER=quantumguard
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD

# ─── Security ────────────────────────────────────────────────
RATE_LIMIT_RPM=60
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-frontend.vercel.app

# ─── v2 Key Management ──────────────────────────────────────
# Master secret for AES-256-GCM key encryption (CHANGE IN PRODUCTION)
QUANTUMGUARD_MASTER_SECRET=CHANGE_ME_IN_PRODUCTION_use_a_64_char_hex_string

# Bootstrap secret for creating the first organization
BOOTSTRAP_SECRET=CHANGE_ME_bootstrap_secret_for_first_org

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Docker Volume Paths ─────────────────────────────────────
MERKLE_STORAGE_DIR=/data/merkle_batches
